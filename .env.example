# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Database
DB_NAME=healthcare_system
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# Flask
SECRET_KEY=generate_with_python_secrets_token_hex_32
FLASK_APP=src/backend/app.py
FLASK_ENV=development

# LLM Provider: huggingface | ollama | openai | groq | anthropic | medgemma
LLM_PROVIDER=groq

# Groq (fast, free tier available — recommended default)
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.1-8b-instant

# HuggingFace
HF_API_KEY=hf_your_token_here
HF_MODEL=microsoft/BiomedNLP-PubMedBERT-base-uncased-abstract-fulltext

# OpenAI (optional)
OPENAI_API_KEY=sk-proj-your_key_here
OPENAI_MODEL=gpt-4o

# Anthropic (optional)
ANTHROPIC_API_KEY=sk-ant-your_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama (optional, self-hosted)
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=mistral

# MedGemma (optional)
# MEDGEMMA_LOCAL=true  → on-device (~8GB RAM); false → HuggingFace Serverless API
MEDGEMMA_MODEL=google/medgemma-4b-it
MEDGEMMA_LOCAL=false
